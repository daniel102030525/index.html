<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Arise-Agencies Limited</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <!-- Header Navigation -->
  <header>
    <div class="logo">Arise-Agencies Ltd</div>
    <nav>
      <ul>
        <li><a href="#home">Home</a></li>
        <li><a href="#properties">Properties</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>
  </header>

  <!-- Hero Section -->
  <section id="home" class="hero">
    <h1>Find Your Dream Property</h1>
    <p>Premium real estate and property management solutions by Arise-Agencies Limited.</p>
  </section>

  <!-- Properties Grid Section -->
  <section id="properties">
    <h2>Featured Listings</h2>
    <div class="grid-container">
      <div class="property-card">
        <h3>Modern 3-Bedroom Apartment</h3>
        <p>Location: Prime Suburbs</p>
        <span class="price">Contact for Price</span>
      </div>
      <div class="property-card">
        <h3>Commercial Office Space</h3>
        <p>Location: Central Business District</p>
        <span class="price">Available Now</span>
      </div>
    </div>
  </section>

  <!-- Property Buyer Contact Form (WhatsApp Link) -->
  <section id="contact" class="form-section">
    <h2>Property Inquiry Form</h2>
    <p>Fill out your details below to chat with an agent instantly via WhatsApp.</p>
    
    <form action="https://wa.me/254700000000" method="get" target="_blank">
      <label for="name">Your Full Name:</label>
      <input type="text" id="name" name="text" placeholder="Enter your name" required>

      <label for="property">Property of Interest:</label>
      <input type="text" id="property" placeholder="e.g., 3-Bedroom Apartment" required>

      <button type="submit" class="submit-btn">Send WhatsApp Message</button>
    </form>
  </section>

  <!-- Footer -->
  <footer>
    <p>&copy; 2026 Arise-Agencies Limited. All rights reserved.</p>
  </footer>

</body>
</html>

